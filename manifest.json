{
  "manifest_version": 3,
  "name": "SmartHoldem Wallet - Prime Edition",
  "short_name": "Prime Wallet",
  "version": "1.4.6",
  "description": "Industrial-grade SmartHoldem (STH) wallet for Browsers. Send, receive, swap and sign.",
  "permissions": ["sidePanel", "storage", "activeTab", "tabs"],
  "action": {
    "default_title": "SmartHoldem Wallet",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": { "default_path": "popup.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.smartholdem.io https://exchange.smartholdem.io https://*.sth.cx https://smartholder.xbts.io"
  }
}
